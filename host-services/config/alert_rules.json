{
  "version": "1.1",
  "scan_interval_seconds": 30,
  "teams_webhook_env_var": "TEAMS_WEBHOOK_URL",
  "default_cooldown_seconds": 300,
  "default_docker_tail_lines": 100,
  "critical_containers": [
    "nginx",
    "app_blue",
    "redis",
    "db",
    "process_excel_completion_listener"
  ],
  "container_check_cooldown_seconds": 300,
  "log_sources": {
    "data_sync": {
      "type": "file",
      "path": "logs/data_sync.log"
    },
    "excel_worker": {
      "type": "file",
      "path": "logs/excel_worker.log"
    },
    "stream_relay": {
      "type": "file",
      "path": "logs/stream_relay.log"
    },
    "looper_health": {
      "type": "file",
      "path": "logs/looper_health.log"
    }
  },
  "rules": [
    {
      "name": "incomplete_websocket_payload",
      "description": "WebSocket consumer received incomplete payload data",
      "pattern": "Incomplete (carton print|pull status) payload received.*=None",
      "sources": ["app_blue", "app_green"],
      "severity": "warning",
      "threshold_count": 50,
      "threshold_window_seconds": 300,
      "cooldown_seconds": 1800,
      "enabled": true
    },
    {
      "name": "network_share_access_failure",
      "description": "Failed to access network share (SharePoint/file server)",
      "pattern": "UnauthorizedAccessException|System error 1223|Access is denied",
      "sources": ["excel_worker"],
      "severity": "error",
      "threshold_count": 3,
      "threshold_window_seconds": 300,
      "cooldown_seconds": 900,
      "enabled": true
    },
    {
      "name": "stream_relay_crash_loop",
      "description": "Stream relay server repeatedly crashing and restarting",
      "pattern": "exited with code \\d+.*Restarting",
      "sources": ["stream_relay"],
      "severity": "error",
      "threshold_count": 5,
      "threshold_window_seconds": 300,
      "cooldown_seconds": 1800,
      "enabled": true
    },
    {
      "name": "database_connection_error",
      "description": "Failed to connect to PostgreSQL database",
      "pattern": "could not connect to server|connection refused|OperationalError.*postgres|psycopg2\\.OperationalError",
      "sources": ["app_blue", "app_green", "data_sync", "db"],
      "severity": "critical",
      "threshold_count": 1,
      "threshold_window_seconds": 60,
      "cooldown_seconds": 300,
      "enabled": true
    },
    {
      "name": "redis_connection_error",
      "description": "Failed to connect to Redis",
      "pattern": "Redis.*(unavailable|Connection (lost|failed|error|refused))|ConnectionError.*redis",
      "sources": ["app_blue", "app_green", "excel_worker"],
      "severity": "error",
      "threshold_count": 3,
      "threshold_window_seconds": 120,
      "cooldown_seconds": 600,
      "enabled": true
    },
    {
      "name": "etl_function_failure",
      "description": "ETL loop function failed with error",
      "pattern": "Function.*failed:|ERROR.*Exception|Traceback \\(most recent call last\\)",
      "sources": ["data_sync"],
      "severity": "warning",
      "threshold_count": 5,
      "threshold_window_seconds": 600,
      "cooldown_seconds": 1800,
      "enabled": true
    },
    {
      "name": "etl_exception_limit",
      "description": "ETL loop hit exception limit - may be stopping",
      "pattern": "Too many exceptions|Exception limit reached",
      "sources": ["data_sync"],
      "severity": "critical",
      "threshold_count": 1,
      "threshold_window_seconds": 60,
      "cooldown_seconds": 3600,
      "enabled": true
    },
    {
      "name": "powershell_job_failure",
      "description": "PowerShell job failed in Excel worker",
      "pattern": "PowerShell (failed|timed out)|failed with code 1",
      "sources": ["excel_worker"],
      "severity": "warning",
      "threshold_count": 3,
      "threshold_window_seconds": 300,
      "cooldown_seconds": 900,
      "enabled": true
    },
    {
      "name": "nginx_restart_loop",
      "description": "Nginx container restarting repeatedly",
      "pattern": "start worker process|signal process started|nginx/|worker process \\d+ exited",
      "sources": ["nginx"],
      "severity": "critical",
      "threshold_count": 3,
      "threshold_window_seconds": 300,
      "cooldown_seconds": 900,
      "enabled": true
    },
    {
      "name": "app_blue_restart_loop",
      "description": "App Blue (Django/Daphne) container restarting repeatedly",
      "pattern": "Starting server at|Application startup complete|Configuring endpoint|Starting Daphne",
      "sources": ["app_blue"],
      "severity": "critical",
      "threshold_count": 3,
      "threshold_window_seconds": 300,
      "cooldown_seconds": 900,
      "enabled": true
    },
    {
      "name": "redis_restart_loop",
      "description": "Redis container restarting repeatedly",
      "pattern": "Ready to accept connections|Server initialized|oO0OoO0OoO0Oo Redis",
      "sources": ["redis"],
      "severity": "critical",
      "threshold_count": 3,
      "threshold_window_seconds": 300,
      "cooldown_seconds": 900,
      "enabled": true
    },
    {
      "name": "db_restart_loop",
      "description": "PostgreSQL container restarting repeatedly",
      "pattern": "database system is ready to accept connections|PostgreSQL init process complete|starting PostgreSQL",
      "sources": ["db"],
      "severity": "critical",
      "threshold_count": 3,
      "threshold_window_seconds": 300,
      "cooldown_seconds": 900,
      "enabled": true
    },
    {
      "name": "excel_listener_restart_loop",
      "description": "Excel completion listener container restarting repeatedly",
      "pattern": "Starting|Listening|Connected to Redis|Initializing",
      "sources": ["process_excel_completion_listener"],
      "severity": "critical",
      "threshold_count": 3,
      "threshold_window_seconds": 300,
      "cooldown_seconds": 900,
      "enabled": true
    },
    {
      "name": "container_fatal_error",
      "description": "Container hit a fatal/unrecoverable error",
      "pattern": "FATAL|Segmentation fault|killed|OOM|out of memory|Cannot allocate memory",
      "sources": ["nginx", "app_blue", "redis", "db", "process_excel_completion_listener"],
      "severity": "critical",
      "threshold_count": 1,
      "threshold_window_seconds": 60,
      "cooldown_seconds": 600,
      "enabled": true
    }
  ]
}
